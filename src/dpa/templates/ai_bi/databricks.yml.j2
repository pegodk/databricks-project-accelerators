# Databricks Asset Bundle — generated by dpa {{ accelerator }}

bundle:
  name: {{ project_slug }}
  deployment:
    lock:
      enabled: false

workspace:
  host: https://<your-workspace-url>  # TODO: replace with your workspace URL

variables:
  catalog:
    default: {{ cfg.catalog }}
    description: Unity Catalog catalog for metric views
  schema:
    default: {{ cfg.schema }}
    description: Schema for metric views

include:
  - resources/dashboards/*.yml
  - resources/genie_spaces/*.yml
  - resources/jobs/*.yml
  - resources/warehouses/*.yml

targets:
  dev:
    mode: development
    default: true

  prod:
    mode: production
    permissions:
      - level: CAN_VIEW
        group_name: users
