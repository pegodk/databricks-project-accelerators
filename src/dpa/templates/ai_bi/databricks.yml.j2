# Databricks Asset Bundle — generated by dpa {{ accelerator }}

bundle:
  name: {{ project_slug }}
  deployment:
    lock:
      enabled: false

variables:
  catalog:
    default: {{ cfg.catalog }}
    description: Unity Catalog catalog for metric views
  schema:
    default: {{ cfg.schema }}
    description: Schema for metric views
  warehouse_id:
    lookup:
      warehouse: "Serverless Starter Warehouse"

include:
  - resources/**/*.yml

targets:
  dev:
    mode: development
    default: true
    workspace:
      host: https://<your-dev-workspace-url>

  prod:
    mode: production
    workspace:
      host: https://<your-prod-workspace-url>
    permissions:
      - level: CAN_VIEW
        group_name: users
