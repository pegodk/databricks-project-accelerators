                "query": {
                  "datasetName": "ds_revenue_by_nation",
                  "fields": [
                    {"name": "customer_nation", "expression": "`customer_nation`"},
                    {"name": "total_revenue",   "expression": "`total_revenue`"},
                    {"name": "order_count",     "expression": "`order_count`"},
                    {"name": "unique_customers","expression": "`unique_customers`"}
                  ],
                  "disaggregated": false
                }
              }
            ],
            "spec": {
              "version": 2,
              "widgetType": "table",
              "encodings": {
                "columns": [
                  {"fieldName": "customer_nation", "displayName": "Country"},
                  {"fieldName": "total_revenue",   "displayName": "Revenue ($)"},
                  {"fieldName": "order_count",     "displayName": "Orders"},
                  {"fieldName": "unique_customers","displayName": "Customers"}
                ]
              },
              "frame": {"showTitle": true, "title": "Revenue by Country"}
