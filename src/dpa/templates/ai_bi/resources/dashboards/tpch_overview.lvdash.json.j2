{
  "displayName": "{{ cfg.dashboard_name }}",
  "datasets": [
    {
      "name": "ds_kpis",
      "displayName": "KPIs",
      "query": "SELECT MEASURE(order_count), MEASURE(total_revenue), MEASURE(avg_order_value), MEASURE(unique_customers) FROM {{ cfg.catalog }}.{{ cfg.schema }}.v_tpch"
    },
    {
      "name": "ds_revenue_by_month",
      "displayName": "Revenue by Month",
      "query": "SELECT order_month, MEASURE(total_revenue), MEASURE(order_count) FROM {{ cfg.catalog }}.{{ cfg.schema }}.v_tpch GROUP BY order_month ORDER BY order_month"
    },
    {
      "name": "ds_revenue_by_segment",
      "displayName": "Revenue by Segment",
      "query": "SELECT market_segment, MEASURE(total_revenue), MEASURE(order_count) FROM {{ cfg.catalog }}.{{ cfg.schema }}.v_tpch GROUP BY market_segment ORDER BY MEASURE(total_revenue) DESC"
    },
    {
      "name": "ds_order_status",
      "displayName": "Order Status",
      "query": "SELECT order_status, MEASURE(total_revenue), MEASURE(order_count) FROM {{ cfg.catalog }}.{{ cfg.schema }}.v_tpch GROUP BY order_status ORDER BY MEASURE(total_revenue) DESC"
    },
    {
      "name": "ds_top_customers",
      "displayName": "Top Customers",
      "query": "SELECT customer_name, market_segment, customer_nation, MEASURE(total_revenue), MEASURE(order_count), MEASURE(avg_order_value) FROM {{ cfg.catalog }}.{{ cfg.schema }}.v_tpch GROUP BY customer_name, market_segment, customer_nation ORDER BY MEASURE(total_revenue) DESC LIMIT 20"
    },
    {
      "name": "ds_revenue_by_nation",
      "displayName": "Revenue by Nation",
      "query": "SELECT customer_nation, MEASURE(total_revenue), MEASURE(order_count), MEASURE(unique_customers) FROM {{ cfg.catalog }}.{{ cfg.schema }}.v_tpch GROUP BY customer_nation ORDER BY MEASURE(total_revenue) DESC"
    },
    {
      "name": "ds_order_priority",
      "displayName": "Order Priority",
      "query": "SELECT order_priority, MEASURE(order_count), MEASURE(total_revenue) FROM {{ cfg.catalog }}.{{ cfg.schema }}.v_tpch GROUP BY order_priority ORDER BY MEASURE(total_revenue) DESC"
    }
  ],
  "pages": [
    {
      "name": "overview",
      "displayName": "Overview",
      "layout": [
        {
          "widget": {
            "name": "w_total_revenue",
            "queries": [
              {
                "name": "q",
                "query": {
                  "datasetName": "ds_kpis",
                  "fields": [
                    {"name": "total_revenue", "expression": "`total_revenue`"}
                  ],
                  "disaggregated": false
                }
              }
            ],
            "spec": {
              "version": 2,
              "widgetType": "counter",
              "encodings": {
                "value": {
                  "fieldName": "total_revenue",
                  "displayName": "Total Revenue"
                }
              },
              "frame": {"showTitle": true, "title": "Total Revenue"}
            }
          },
          "position": {"x": 0, "y": 0, "width": 2, "height": 3}
        },
        {
          "widget": {
            "name": "w_order_count",
            "queries": [
              {
                "name": "q",
                "query": {
                  "datasetName": "ds_kpis",
                  "fields": [
                    {"name": "order_count", "expression": "`order_count`"}
                  ],
                  "disaggregated": false
                }
              }
            ],
            "spec": {
              "version": 2,
              "widgetType": "counter",
              "encodings": {
                "value": {
                  "fieldName": "order_count",
                  "displayName": "Total Orders"
                }
              },
              "frame": {"showTitle": true, "title": "Total Orders"}
            }
          },
          "position": {"x": 2, "y": 0, "width": 2, "height": 3}
        },
        {
          "widget": {
            "name": "w_avg_order_value",
            "queries": [
              {
                "name": "q",
                "query": {
                  "datasetName": "ds_kpis",
                  "fields": [
                    {"name": "avg_order_value", "expression": "`avg_order_value`"}
                  ],
                  "disaggregated": false
                }
              }
            ],
            "spec": {
              "version": 2,
              "widgetType": "counter",
              "encodings": {
                "value": {
                  "fieldName": "avg_order_value",
                  "displayName": "Avg Order Value"
                }
              },
              "frame": {"showTitle": true, "title": "Avg Order Value"}
            }
          },
          "position": {"x": 4, "y": 0, "width": 2, "height": 3}
        },
        {
          "widget": {
            "name": "w_revenue_by_month",
            "queries": [
              {
                "name": "q",
                "query": {
                  "datasetName": "ds_revenue_by_month",
                  "fields": [
                    {"name": "order_month",    "expression": "`order_month`"},
                    {"name": "total_revenue",  "expression": "`total_revenue`"}
                  ],
                  "disaggregated": false
                }
              }
            ],
            "spec": {
              "version": 2,
              "widgetType": "area",
              "encodings": {
                "x": {"fieldName": "order_month",   "displayName": "Month", "type": "temporal"},
                "y": {"fieldName": "total_revenue",  "displayName": "Revenue ($)"}
              },
              "frame": {"showTitle": true, "title": "Monthly Revenue Trend"}
            }
          },
          "position": {"x": 0, "y": 3, "width": 6, "height": 6}
        },
        {
          "widget": {
            "name": "w_revenue_by_segment",
            "queries": [
              {
                "name": "q",
                "query": {
                  "datasetName": "ds_revenue_by_segment",
                  "fields": [
                    {"name": "market_segment", "expression": "`market_segment`"},
                    {"name": "total_revenue",  "expression": "`total_revenue`"}
                  ],
                  "disaggregated": false
                }
              }
            ],
            "spec": {
              "version": 2,
              "widgetType": "bar",
              "encodings": {
                "x": {"fieldName": "market_segment", "displayName": "Market Segment"},
                "y": {"fieldName": "total_revenue",  "displayName": "Revenue ($)"}
              },
              "frame": {"showTitle": true, "title": "Revenue by Market Segment"}
            }
          },
          "position": {"x": 0, "y": 9, "width": 3, "height": 5}
        },
        {
          "widget": {
            "name": "w_order_priority",
            "queries": [
              {
                "name": "q",
                "query": {
                  "datasetName": "ds_order_priority",
                  "fields": [
                    {"name": "order_priority", "expression": "`order_priority`"},
                    {"name": "total_revenue",  "expression": "`total_revenue`"}
                  ],
                  "disaggregated": false
                }
              }
            ],
            "spec": {
              "version": 2,
              "widgetType": "pie",
              "encodings": {
                "angle": {"fieldName": "total_revenue",  "displayName": "Revenue ($)"},
                "label": {"fieldName": "order_priority", "displayName": "Priority"}
              },
              "frame": {"showTitle": true, "title": "Revenue by Order Priority"}
            }
          },
          "position": {"x": 3, "y": 9, "width": 3, "height": 5}
        }
      ]
    },
