# Databricks Asset Bundle — generated by dpa {{ accelerator }}

bundle:
  name: {{ project_slug }}

workspace:
  host: https://<your-workspace-url>  # TODO: replace with your workspace URL

include:
  - resources/**/*.yml

targets:
  dev:
    mode: development
    default: true

  prod:
    mode: production
    permissions:
      - level: CAN_VIEW
        group_name: users
