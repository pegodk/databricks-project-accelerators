# Databricks Asset Bundle — generated by dpa {{ accelerator }}

bundle:
  name: {{ project_slug }}

include:
  - resources/**/*.yml

targets:
  dev:
    mode: development
    default: true
    workspace:
      host: https://<your-dev-workspace-url>

  prod:
    mode: production
    workspace:
      host: https://<your-prod-workspace-url>
    permissions:
      - level: CAN_VIEW
        group_name: users
