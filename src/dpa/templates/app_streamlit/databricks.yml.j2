# Databricks Asset Bundle — generated by dia {{ accelerator }}
# Edit the workspace host and SQL warehouse HTTP path to match your environment.

bundle:
  name: {{ project_slug }}

variables:
  sql_warehouse_http_path:
    description: HTTP path of the SQL warehouse the Streamlit app will query
    default: ""

include:
  - resources/**/*.yml

targets:
  dev:
    mode: development
    default: true
    workspace:
      host: ${workspace.host}

  prod:
    mode: production
    workspace:
      host: ${workspace.host}
    permissions:
      - level: CAN_VIEW
        group_name: users
