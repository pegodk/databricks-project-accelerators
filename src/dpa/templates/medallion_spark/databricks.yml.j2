bundle:
  name: {{ project_slug }}
  deployment:
    lock:
      enabled: false

variables:
  bronze_catalog:
    default: {{ cfg.bronze_catalog }}
    description: Catalog for raw ingested data
  gold_catalog:
    default: {{ cfg.gold_catalog }}
    description: Catalog for business-level aggregates
  bronze_schema:
    default: {{ cfg.bronze_schema }}
    description: Schema for raw ingested data (source-specific, e.g. tpch)
  gold_schema:
    default: {{ cfg.gold_schema }}
    description: Schema for business-level aggregates (data-product-specific, e.g. tpch_model)
include:
  - resources/**/*.yml

targets:
  dev:
    mode: development
    default: true
    workspace:
      host: https://<your-dev-workspace-url>
  prod:
    mode: production
    workspace:
      host: https://<your-prod-workspace-url>
    permissions:
      - level: CAN_VIEW
        group_name: users
