# Databricks notebook source
# MAGIC %md
# MAGIC # Bronze — Raw Ingestion
# MAGIC
# MAGIC Streams the TPCH sample tables into the bronze catalog using Spark Structured Streaming
# MAGIC with `trigger(availableNow=True)`. Each run processes all data added since the last checkpoint,
# MAGIC making it safe to schedule repeatedly without re-ingesting existing rows.
# MAGIC
# MAGIC **Source:** `samples.tpch`
# MAGIC **Target:** `${var.bronze_catalog}.${var.bronze_schema}`

# COMMAND ----------

dbutils.widgets.text("bronze_catalog", "{{ cfg.bronze_catalog }}")
dbutils.widgets.text("bronze_schema", "{{ cfg.bronze_schema }}")

bronze_catalog = dbutils.widgets.get("bronze_catalog")
bronze_schema = dbutils.widgets.get("bronze_schema")
checkpoint_base = f"dbfs:/checkpoints/{bronze_catalog}/{bronze_schema}"

# COMMAND ----------

spark.sql(f"CREATE SCHEMA IF NOT EXISTS {bronze_catalog}.{bronze_schema}")

# COMMAND ----------

def stream_table(source: str, target: str, checkpoint: str) -> None:
    (
        spark.readStream
        .format("delta")
        .option("ignoreChanges", "true")
        .table(source)
        .writeStream
        .format("delta")
        .outputMode("append")
        .option("checkpointLocation", checkpoint)
        .option("mergeSchema", "true")
        .trigger(availableNow=True)
        .toTable(target)
        .awaitTermination()
    )

# COMMAND ----------

for table in ["orders", "lineitem", "customer", "nation", "region"]:
    stream_table(
        source=f"samples.tpch.{table}",
        target=f"{bronze_catalog}.{bronze_schema}.{table}",
        checkpoint=f"{checkpoint_base}/{table}",
    )
    print(f"Ingested samples.tpch.{table} → {bronze_catalog}.{bronze_schema}.{table}")
