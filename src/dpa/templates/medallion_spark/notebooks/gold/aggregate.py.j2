# Databricks notebook source
# MAGIC %md
# MAGIC # Gold — Dimensional Model
# MAGIC
# MAGIC Builds a star schema from the bronze layer (TPCH tables).
# MAGIC
# MAGIC | Table | Grain | Description |
# MAGIC |---|---|---|
# MAGIC | `dim_customer` | customer | Customer with nation and region hierarchy |
# MAGIC | `dim_part` | part | Part catalogue |
# MAGIC | `dim_supplier` | supplier | Supplier with nation and region hierarchy |
# MAGIC | `fact_order` | order line item | Line-level measures with calendar and lag columns |
# MAGIC
# MAGIC **Source:** `${var.bronze_catalog}.${var.bronze_schema}`
# MAGIC **Target:** `${var.gold_catalog}.${var.gold_schema}`

# COMMAND ----------

dbutils.widgets.text("bronze_catalog", "{{ cfg.bronze_catalog }}")
dbutils.widgets.text("gold_catalog", "{{ cfg.gold_catalog }}")
dbutils.widgets.text("bronze_schema", "{{ cfg.bronze_schema }}")
dbutils.widgets.text("gold_schema", "{{ cfg.gold_schema }}")

bronze_catalog = dbutils.widgets.get("bronze_catalog")
gold_catalog   = dbutils.widgets.get("gold_catalog")
bronze_schema  = dbutils.widgets.get("bronze_schema")
gold_schema    = dbutils.widgets.get("gold_schema")
spark.sql(f"CREATE SCHEMA IF NOT EXISTS {gold_catalog}.{gold_schema}")

# COMMAND ----------

from pyspark.sql import functions as F

# Shared dimension tables read once
nation = spark.table(f"{bronze_catalog}.{bronze_schema}.nation")
region = spark.table(f"{bronze_catalog}.{bronze_schema}.region")

# COMMAND ----------

# dim_customer

customer = spark.table(f"{bronze_catalog}.{bronze_schema}.customer")

dim_customer = (
    customer
    .join(nation, customer.c_nationkey == nation.n_nationkey)
    .join(region, nation.n_regionkey == region.r_regionkey)
    .select(
        F.col("c_custkey").alias("customer_key"),
        F.col("c_name").alias("customer_name"),
        F.col("c_address").alias("customer_address"),
        F.col("c_phone").alias("customer_phone"),
        F.col("c_acctbal").alias("customer_acctbal"),
        F.col("c_mktsegment").alias("customer_segment"),
        F.coalesce(F.col("n_name"), F.lit("Unknown")).alias("customer_nation"),
        F.coalesce(F.col("r_name"), F.lit("Unknown")).alias("customer_region"),
    )
)
dim_customer.write.mode("overwrite").saveAsTable(f"{gold_catalog}.{gold_schema}.dim_customer")
print(f"dim_customer: {dim_customer.count():,} rows")

# COMMAND ----------

# dim_part

part = spark.table(f"{bronze_catalog}.{bronze_schema}.part")

dim_part = part.select(
    F.col("p_partkey").alias("part_key"),
    F.col("p_name").alias("part_name"),
    F.col("p_mfgr").alias("part_manufacturer"),
    F.col("p_brand").alias("part_brand"),
    F.col("p_type").alias("part_type"),
    F.col("p_size").alias("part_size"),
    F.col("p_container").alias("part_container"),
    F.col("p_retailprice").alias("part_retail_price"),
    F.col("p_comment").alias("part_comment"),
)
dim_part.write.mode("overwrite").saveAsTable(f"{gold_catalog}.{gold_schema}.dim_part")
print(f"dim_part: {dim_part.count():,} rows")

# COMMAND ----------

# dim_supplier

supplier = spark.table(f"{bronze_catalog}.{bronze_schema}.supplier")

dim_supplier = (
    supplier
    .join(nation, supplier.s_nationkey == nation.n_nationkey)
    .join(region, nation.n_regionkey == region.r_regionkey)
    .select(
        F.col("s_suppkey").alias("supplier_key"),
        F.col("s_name").alias("supplier_name"),
        F.col("s_address").alias("supplier_address"),
        F.col("s_phone").alias("supplier_phone"),
        F.coalesce(F.col("n_name"), F.lit("Unknown")).alias("supplier_nation"),
        F.coalesce(F.col("r_name"), F.lit("Unknown")).alias("supplier_region"),
    )
)
dim_supplier.write.mode("overwrite").saveAsTable(f"{gold_catalog}.{gold_schema}.dim_supplier")
print(f"dim_supplier: {dim_supplier.count():,} rows")

# COMMAND ----------

# fact_order — grain: one row per order line item

lineitem = spark.table(f"{bronze_catalog}.{bronze_schema}.lineitem")
orders   = spark.table(f"{bronze_catalog}.{bronze_schema}.orders")
partsupp = spark.table(f"{bronze_catalog}.{bronze_schema}.partsupp")

fact_order = (
    lineitem
    .join(orders,   lineitem.l_orderkey == orders.o_orderkey)
    .join(partsupp, (lineitem.l_partkey == partsupp.ps_partkey) & (lineitem.l_suppkey == partsupp.ps_suppkey), "left")
    .select(
        F.col("o_orderdate").alias("calendar_order_key"),
        F.col("l_commitdate").alias("calendar_commit_key"),
        F.col("l_receiptdate").alias("calendar_receipt_key"),
        F.col("l_shipdate").alias("calendar_ship_key"),
        F.col("o_custkey").alias("customer_key"),
        F.col("l_partkey").alias("part_key"),
        F.col("l_suppkey").alias("supplier_key"),
        F.col("l_orderkey").alias("order_header_code"),
        F.col("l_linenumber").alias("order_line_code"),
        F.col("l_quantity").alias("order_quantity"),
        F.col("l_extendedprice").alias("order_extended_price_usd"),
        F.col("l_discount").alias("order_discount_usd"),
        F.col("l_tax").alias("order_tax_usd"),
        F.col("ps_supplycost").alias("part_supply_cost_usd"),
        F.datediff(F.col("l_commitdate"),  F.col("o_orderdate")).alias("order_commit_lag_days"),
        F.datediff(F.col("l_receiptdate"), F.col("o_orderdate")).alias("order_receipt_lag_days"),
        F.datediff(F.col("l_shipdate"),    F.col("o_orderdate")).alias("order_ship_lag_days"),
    )
)
fact_order.write.mode("overwrite").saveAsTable(f"{gold_catalog}.{gold_schema}.fact_order")
print(f"fact_order: {fact_order.count():,} rows")
