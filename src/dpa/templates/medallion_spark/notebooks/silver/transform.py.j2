# Databricks notebook source
# MAGIC %md
# MAGIC # Silver — Cleansed & Enriched Orders
# MAGIC
# MAGIC Streams from bronze `orders` and joins with `customer`, `nation`, and `region`
# MAGIC dimension tables (stream-static join). Writes an enriched orders table to the silver catalog.
# MAGIC
# MAGIC **Source:** `${var.bronze_catalog}.${var.schema}`
# MAGIC **Target:** `${var.silver_catalog}.${var.schema}.orders_enriched`

# COMMAND ----------

dbutils.widgets.text("bronze_catalog", "{{ cfg.bronze_catalog }}")
dbutils.widgets.text("silver_catalog", "{{ cfg.silver_catalog }}")
dbutils.widgets.text("schema", "{{ cfg.schema }}")

bronze_catalog = dbutils.widgets.get("bronze_catalog")
silver_catalog = dbutils.widgets.get("silver_catalog")
schema = dbutils.widgets.get("schema")
checkpoint_base = f"dbfs:/checkpoints/{silver_catalog}/{schema}"

# COMMAND ----------

spark.sql(f"CREATE SCHEMA IF NOT EXISTS {silver_catalog}.{schema}")

# COMMAND ----------

from pyspark.sql import functions as F

# Dimension tables are small and static — batch-load for stream-static joins
customers = spark.table(f"{bronze_catalog}.{schema}.customer")
nations   = spark.table(f"{bronze_catalog}.{schema}.nation")
regions   = spark.table(f"{bronze_catalog}.{schema}.region")

dim = (
    customers
    .join(nations, customers.c_nationkey == nations.n_nationkey)
    .join(regions, nations.n_regionkey == regions.r_regionkey)
    .select(
        F.col("c_custkey"),
        F.col("c_name").alias("customer_name"),
        F.col("c_mktsegment").alias("market_segment"),
        F.col("n_name").alias("nation"),
        F.col("r_name").alias("region"),
    )
)

# COMMAND ----------

(
    spark.readStream
    .format("delta")
    .table(f"{bronze_catalog}.{schema}.orders")
    .join(dim, F.col("o_custkey") == F.col("c_custkey"))
    .select(
        F.col("o_orderkey").alias("order_key"),
        F.col("o_orderdate").cast("date").alias("order_date"),
        F.date_trunc("month", F.col("o_orderdate")).alias("order_month"),
        F.col("o_orderstatus").alias("order_status"),
        F.col("o_orderpriority").alias("order_priority"),
        F.col("o_totalprice").alias("total_price"),
        F.col("customer_name"),
        F.col("market_segment"),
        F.col("nation"),
        F.col("region"),
    )
    .writeStream
    .format("delta")
    .outputMode("append")
    .option("checkpointLocation", f"{checkpoint_base}/orders_enriched")
    .trigger(availableNow=True)
    .toTable(f"{silver_catalog}.{schema}.orders_enriched")
    .awaitTermination()
)
