# Databricks Asset Bundle — generated by dpa {{ accelerator }}

bundle:
  name: {{ project_slug }}

variables:
  bronze_catalog:
    description: Unity Catalog for the bronze (raw) layer
    default: bronze_dev
  silver_catalog:
    description: Unity Catalog for the silver (cleaned) layer
    default: silver_dev
  gold_catalog:
    description: Unity Catalog for the gold (dimensional model) layer
    default: gold_dev

include:
  - resources/**/*.yml

targets:
  dev:
    mode: development
    default: true
    workspace:
      host: https://<your-dev-workspace-url>

  prod:
    mode: production
    workspace:
      host: https://<your-prod-workspace-url>
    permissions:
      - level: CAN_VIEW
        group_name: users
