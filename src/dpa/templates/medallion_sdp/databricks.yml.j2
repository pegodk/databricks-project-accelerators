# Databricks Asset Bundle — generated by dpa {{ accelerator }}

bundle:
  name: {{ project_slug }}

workspace:
  host: https://<your-workspace-url>  # TODO: replace with your workspace URL

variables:
  bronze_catalog:
    description: Unity Catalog for the bronze (raw) layer
    default: main
  silver_catalog:
    description: Unity Catalog for the silver (cleaned) layer
    default: main
  gold_catalog:
    description: Unity Catalog for the gold (dimensional model) layer
    default: main

include:
  - resources/**/*.yml

targets:
  dev:
    mode: development
    default: true

  prod:
    mode: production
    permissions:
      - level: CAN_VIEW
        group_name: users
