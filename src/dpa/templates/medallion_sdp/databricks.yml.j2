# Databricks Asset Bundle — generated by dpa {{ accelerator }}

bundle:
  name: {{ project_slug }}

variables:
  bronze_catalog:
    description: Unity Catalog for the bronze (raw) layer
    default: bronze
  silver_catalog:
    description: Unity Catalog for the silver (cleaned) layer
    default: silver
  gold_catalog:
    description: Unity Catalog for the gold (dimensional model) layer
    default: gold

include:
  - resources/**/*.yml

targets:
  dev:
    mode: development
    default: true
    workspace:
      host: ${workspace.host}
    variables:
      bronze_catalog: bronze_dev
      silver_catalog: silver_dev
      gold_catalog: gold_dev

  prod:
    mode: production
    workspace:
      host: ${workspace.host}
    variables:
      bronze_catalog: bronze_prd
      silver_catalog: silver_prd
      gold_catalog: gold_prd
    permissions:
      - level: CAN_VIEW
        group_name: users
