"""Synthetic data source — PySpark Python DataSource (DBR 14.0+).

Generates synthetic data using Faker.
Supported tables: {{ cfg.bronze_tables | map(attribute='name') | join(' | ') }}

Usage inside a DLT pipeline:
    spark.dataSource.register({{ cfg.source_class }})
    df = spark.read.format("{{ cfg.source_class }}").option("table", "events").load()

Options:
    table          — which table to generate (required)
    numRows        — total rows to produce (default: 10 000)
    numPartitions  — number of Spark partitions (default: 10)
"""

from __future__ import annotations

from pyspark.sql.datasource import DataSource, DataSourceReader
from pyspark.sql.types import StringType, StructField, StructType, TimestampType

# ---------------------------------------------------------------------------
# Schema registry
# ---------------------------------------------------------------------------

_SCHEMAS: dict[str, StructType] = {
{% for table in cfg.bronze_tables %}
    "{{ table.name }}": StructType([
{% for key in table.primary_keys %}
        StructField("{{ key }}", StringType(), nullable=False),
{% endfor %}
        StructField("value", StringType(), nullable=True),
        StructField("created_at", TimestampType(), nullable=False),
        StructField("attributes", StringType(), nullable=True),
    ]),
{% endfor %}
}


def _generate_value(field: StructField, fake) -> object:
    if isinstance(field.dataType, TimestampType):
        return fake.date_time_between(start_date="-3y")
    if field.name.endswith("_id") or not field.nullable:
        return fake.uuid4()
    return fake.sentence(nb_words=4)


# ---------------------------------------------------------------------------
# DataSource
# ---------------------------------------------------------------------------

class {{ cfg.source_class }}(DataSource):
    @classmethod
    def name(cls) -> str:
        return "{{ cfg.source_class }}"

    def schema(self) -> StructType:
        table = self.options.get("table")
        if table not in _SCHEMAS:
            raise ValueError(f"Unknown table {table!r}. Choose from: {list(_SCHEMAS)}")
        return _SCHEMAS[table]

    def reader(self, schema: StructType) -> "{{ cfg.source_class }}Reader":
        return {{ cfg.source_class }}Reader(schema, self.options)


# ---------------------------------------------------------------------------
# DataSourceReader
# ---------------------------------------------------------------------------

class {{ cfg.source_class }}Reader(DataSourceReader):
    def __init__(self, schema: StructType, options: dict[str, str]) -> None:
        self._schema = schema
        self.table = options.get("table")
        self.num_rows = int(options.get("numRows", 10_000))
        self.num_partitions = int(options.get("numPartitions", 10))

    def partitions(self) -> list[dict]:
        rows_each = max(1, self.num_rows // self.num_partitions)
        return [{"start": i * rows_each, "n": rows_each} for i in range(self.num_partitions)]

    def read(self, partition: dict):  # noqa: ANN201
        from faker import Faker

        fake = Faker()
        Faker.seed(partition["start"])
        for _ in range(partition["n"]):
            yield tuple(_generate_value(f, fake) for f in self._schema.fields)
