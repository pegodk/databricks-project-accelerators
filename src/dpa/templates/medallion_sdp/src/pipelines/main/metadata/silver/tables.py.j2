"""Silver layer table configuration with data quality expectations.

expectations_fail_update — stop the pipeline update on violation
expectations_drop_row    — silently drop the offending row
expectations_warn        — log the violation, let the row through
"""

TABLE_CONFIGS = [
{% for table in cfg.bronze_tables %}
{% set exps = cfg.get('silver_expectations', {}).get(table.name, {}) %}
    {
        "source": "{{ table.name }}",
        "destination": "{{ table.name }}",
        "primary_keys": {{ table.primary_keys | tojson }},
        "description": "{{ table.description }} (validated)",
        "expectations_fail_update": {{ exps.get('fail_update', {}) | tojson }},
        "expectations_drop_row": {{ exps.get('drop_row', {}) | tojson }},
        "expectations_warn": {{ exps.get('warn', {}) | tojson }},
    },
{% endfor %}
]
