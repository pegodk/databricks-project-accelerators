"""Bronze layer: ingest raw data from the fake data source into DLT tables.

Each table is defined in metadata/bronze/tables.py.
Swap source_class to point at a real data source.
"""

from __future__ import annotations

import os
import sys

import dlt
from pyspark.sql import SparkSession

# framework is under src/ — 4 levels up from transformations/bronze/
sys.path.insert(0, os.path.join(os.path.dirname(__file__), "../../../.."))
# metadata package is under src/pipelines/main/ — 2 levels up
sys.path.insert(0, os.path.join(os.path.dirname(__file__), "../.."))

from framework.dlt import create_dlt_table
from framework.utils import add_ingest_timestamp
from metadata.bronze.tables import TABLE_CONFIGS
from data_sources.synthetic_data_source import {{ cfg.source_class }}

spark = SparkSession.builder.getOrCreate()
spark.dataSource.register({{ cfg.source_class }})


def _make_bronze_table(source_class: str, table_name: str, primary_keys: list, description: str) -> None:
    """Register one DLT table via a factory to avoid late-binding closure issues."""

    @create_dlt_table(name=table_name, comment=description, primary_keys=primary_keys)
    def _table(tname: str = table_name, src: str = source_class) -> object:
        return (
            spark.read.format(src)
            .option("table", tname)
            .load()
            .transform(add_ingest_timestamp)
        )


for _meta in TABLE_CONFIGS:
    _make_bronze_table(
        source_class=_meta["source_class"],
        table_name=_meta["destination"],
        primary_keys=_meta["primary_keys"],
        description=_meta.get("description", ""),
    )
