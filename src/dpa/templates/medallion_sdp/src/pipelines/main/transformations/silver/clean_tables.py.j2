"""Silver layer: read from bronze DLT tables and apply data quality expectations.

Expectations are declared in metadata/silver/tables.py.
DLT will enforce them according to their type (fail_update / drop_row / warn).
"""

from __future__ import annotations

import os
import sys

import dlt

sys.path.insert(0, os.path.join(os.path.dirname(__file__), "../../../.."))
sys.path.insert(0, os.path.join(os.path.dirname(__file__), "../.."))

from framework.dlt import create_dlt_table
from metadata.silver.tables import TABLE_CONFIGS


def _make_silver_table(
    source: str,
    destination: str,
    primary_keys: list,
    description: str,
    expectations_fail_update: dict,
    expectations_drop_row: dict,
    expectations_warn: dict,
) -> None:
    @create_dlt_table(
        name=destination,
        comment=description,
        primary_keys=primary_keys,
        expectations_fail_update=expectations_fail_update,
        expectations_drop_row=expectations_drop_row,
        expectations_warn=expectations_warn,
    )
    def _table(src: str = source) -> object:
        return dlt.read(src)


for _meta in TABLE_CONFIGS:
    _make_silver_table(
        source=_meta["source"],
        destination=_meta["destination"],
        primary_keys=_meta.get("primary_keys", []),
        description=_meta.get("description", ""),
        expectations_fail_update=_meta.get("expectations_fail_update", {}),
        expectations_drop_row=_meta.get("expectations_drop_row", {}),
        expectations_warn=_meta.get("expectations_warn", {}),
    )
