"""TPCH Sales Analytics — Streamlit app generated by dpa {{ accelerator }}."""

import os

import pandas as pd
import plotly.express as px
import psycopg
import streamlit as st
from databricks import sql
from databricks.sdk import WorkspaceClient
from psycopg.rows import dict_row
from psycopg_pool import ConnectionPool

HOSTNAME = os.environ.get("DATABRICKS_HOST", "").replace("https://", "")
HTTP_PATH = os.environ.get("DATABRICKS_HTTP_PATH", "")

# Injected by Databricks Apps runtime when a postgres resource is attached.
PGHOST = os.environ.get("PGHOST", "")
PGDATABASE = os.environ.get("PGDATABASE", "databricks_postgres")
PGUSER = os.environ.get("DATABRICKS_CLIENT_ID", "")  # app's service principal identity
PGPORT = os.environ.get("PGPORT", "5432")
PGSSLMODE = os.environ.get("PGSSLMODE", "require")
ENDPOINT_NAME = os.environ.get("ENDPOINT_NAME", "")

LAKEBASE_READY = bool(PGHOST and ENDPOINT_NAME and PGUSER)

st.set_page_config(
    page_title="TPCH Sales Analytics",
    page_icon="📊",
    layout="wide",
)


# ── Connections ───────────────────────────────────────────────────────────────

@st.cache_data(ttl=3600, show_spinner="Querying Databricks...")
def run_query(query: str) -> pd.DataFrame:
    with sql.connect(server_hostname=HOSTNAME, http_path=HTTP_PATH) as conn:
        with conn.cursor() as cursor:
            cursor.execute(query)
            return cursor.fetchall_arrow().to_pandas()


@st.cache_resource
def _lakebase_pool() -> ConnectionPool:
    """Connection pool with automatic OAuth token rotation (tokens expire after 1 h)."""
    _w = WorkspaceClient()

    class _OAuthConn(psycopg.Connection):
        @classmethod
        def connect(cls, conninfo="", **kwargs):
            cred = _w.postgres.generate_database_credential(endpoint=ENDPOINT_NAME)
            kwargs["password"] = cred.token
            return super().connect(conninfo, **kwargs)

    return ConnectionPool(
        conninfo=f"host={PGHOST} dbname={PGDATABASE} user={PGUSER} port={PGPORT} sslmode={PGSSLMODE}",
        connection_class=_OAuthConn,
        min_size=1,
        max_size=5,
        open=True,
    )


def _ensure_schema(conn: psycopg.Connection) -> None:
    with conn.cursor() as cur:
        cur.execute("""
            CREATE TABLE IF NOT EXISTS customer_master (
                c_custkey      BIGINT PRIMARY KEY,
                display_name   TEXT,
                market_segment TEXT,
                updated_at     TIMESTAMPTZ DEFAULT now()
            )
        """)
    conn.commit()


def _load_overrides(conn: psycopg.Connection) -> pd.DataFrame:
    with conn.cursor(row_factory=dict_row) as cur:
        cur.execute("SELECT c_custkey, display_name, market_segment FROM customer_master")
        rows = cur.fetchall()
    return pd.DataFrame(rows) if rows else pd.DataFrame(columns=["c_custkey", "display_name", "market_segment"])


def _upsert_overrides(conn: psycopg.Connection, rows: list[dict]) -> None:
    with conn.cursor() as cur:
        cur.executemany(
            """
            INSERT INTO customer_master (c_custkey, display_name, market_segment, updated_at)
            VALUES (%s, %s, %s, now())
            ON CONFLICT (c_custkey) DO UPDATE SET
                display_name   = EXCLUDED.display_name,
                market_segment = EXCLUDED.market_segment,
                updated_at     = now()
            """,
            [(r["c_custkey"], r["display_name"], r["market_segment"]) for r in rows],
        )
    conn.commit()


def fmt_currency(value: float) -> str:
    if value >= 1_000_000_000:
        return f"${value / 1_000_000_000:.1f}B"
    if value >= 1_000_000:
        return f"${value / 1_000_000:.1f}M"
    return f"${value:,.0f}"


# ── Sidebar ──────────────────────────────────────────────────────────────────
with st.sidebar:
    st.title("TPCH Analytics")
    st.caption("Powered by `samples.tpch` — Databricks built-in sample dataset.")
    st.divider()
    if not HTTP_PATH:
        st.warning(
            "**DATABRICKS_HTTP_PATH** is not set.\n\n"
            "Set it via the app environment config or a `.env` file to connect to a SQL warehouse."
        )
    if not LAKEBASE_READY:
        st.warning(
            "**Lakebase** is not configured — master data tab will be unavailable.\n\n"
            "Set `PGHOST` and `ENDPOINT_NAME` after deploying the Lakebase project."
        )
    else:
        st.success("Lakebase connected")

# ── Tabs ──────────────────────────────────────────────────────────────────────
tab_analytics, tab_master = st.tabs(["Analytics", "Master Data"])

# ── Analytics tab ─────────────────────────────────────────────────────────────
with tab_analytics:
    try:
        kpis = run_query("""
            SELECT
                COUNT(*)                          AS total_orders,
                SUM(o_totalprice)                 AS total_revenue,
                AVG(o_totalprice)                 AS avg_order_value,
                COUNT(DISTINCT o_custkey)         AS unique_customers
            FROM samples.tpch.orders
        """)

        monthly = run_query("""
            SELECT
                DATE_TRUNC('month', o_orderdate)  AS order_month,
                SUM(o_totalprice)                 AS monthly_revenue,
                COUNT(*)                          AS order_count
            FROM samples.tpch.orders
            GROUP BY 1
            ORDER BY 1
        """)

        by_segment = run_query("""
            SELECT
                c.c_mktsegment                    AS market_segment,
                SUM(o.o_totalprice)               AS total_revenue,
                COUNT(o.o_orderkey)               AS order_count
            FROM samples.tpch.orders o
            JOIN samples.tpch.customer c ON o.o_custkey = c.c_custkey
            GROUP BY 1
            ORDER BY 2 DESC
        """)

        by_status = run_query("""
            SELECT
                o_orderstatus                     AS order_status,
                COUNT(*)                          AS order_count
            FROM samples.tpch.orders
            GROUP BY 1
        """)

        top_customers = run_query("""
            SELECT
                c.c_name                          AS customer_name,
                c.c_mktsegment                    AS market_segment,
                n.n_name                          AS nation,
                SUM(o.o_totalprice)               AS total_revenue,
                COUNT(o.o_orderkey)               AS total_orders,
                AVG(o.o_totalprice)               AS avg_order_value
            FROM samples.tpch.orders o
            JOIN samples.tpch.customer c  ON o.o_custkey  = c.c_custkey
            JOIN samples.tpch.nation   n  ON c.c_nationkey = n.n_nationkey
            GROUP BY 1, 2, 3
            ORDER BY 4 DESC
            LIMIT 20
        """)

        shipmode = run_query("""
            SELECT
                l.l_shipmode                      AS ship_mode,
                SUM(l.l_extendedprice)            AS gross_revenue,
                SUM(l.l_extendedprice * (1 - l.l_discount)) AS net_revenue,
                AVG(l.l_discount)                 AS avg_discount,
                COUNT(*)                          AS line_count
            FROM samples.tpch.lineitem l
            GROUP BY 1
            ORDER BY 2 DESC
        """)

    except Exception as exc:
        st.error(f"Could not connect to Databricks: {exc}")
        st.stop()

    st.header("TPCH Sales Overview")

    col1, col2, col3, col4 = st.columns(4)
    col1.metric("Total Revenue",    fmt_currency(kpis["total_revenue"].iloc[0]))
    col2.metric("Total Orders",     f"{int(kpis['total_orders'].iloc[0]):,}")
    col3.metric("Avg Order Value",  fmt_currency(kpis["avg_order_value"].iloc[0]))
    col4.metric("Unique Customers", f"{int(kpis['unique_customers'].iloc[0]):,}")

    st.divider()

    st.subheader("Monthly Revenue")
    monthly["order_month"] = pd.to_datetime(monthly["order_month"])
    fig_trend = px.area(
        monthly,
        x="order_month",
        y="monthly_revenue",
        labels={"order_month": "Month", "monthly_revenue": "Revenue ($)"},
        color_discrete_sequence=["#FF3621"],
    )
    fig_trend.update_layout(showlegend=False, margin={"t": 10})
    st.plotly_chart(fig_trend, use_container_width=True)

    st.divider()

    col_left, col_right = st.columns(2)

    with col_left:
        st.subheader("Revenue by Market Segment")
        fig_seg = px.bar(
            by_segment,
            x="market_segment",
            y="total_revenue",
            labels={"market_segment": "Segment", "total_revenue": "Revenue ($)"},
            color="market_segment",
            color_discrete_sequence=px.colors.qualitative.Set2,
        )
        fig_seg.update_layout(showlegend=False, margin={"t": 10})
        st.plotly_chart(fig_seg, use_container_width=True)

    with col_right:
        st.subheader("Orders by Status")
        status_labels = {"F": "Fulfilled", "O": "Open", "P": "Pending"}
        by_status["label"] = by_status["order_status"].map(status_labels).fillna(by_status["order_status"])
        fig_status = px.pie(
            by_status,
            names="label",
            values="order_count",
            color_discrete_sequence=px.colors.qualitative.Pastel,
            hole=0.4,
        )
        fig_status.update_layout(margin={"t": 10})
        st.plotly_chart(fig_status, use_container_width=True)

    st.divider()

    st.subheader("Revenue & Discount by Ship Mode")
    fig_ship = px.bar(
        shipmode,
        x="ship_mode",
        y=["gross_revenue", "net_revenue"],
        barmode="group",
        labels={"ship_mode": "Ship Mode", "value": "Revenue ($)", "variable": "Type"},
        color_discrete_sequence=["#1F77B4", "#FF7F0E"],
    )
    fig_ship.update_layout(margin={"t": 10})
    st.plotly_chart(fig_ship, use_container_width=True)

    st.divider()

    st.subheader("Top 20 Customers by Revenue")
    top_customers["total_revenue"] = top_customers["total_revenue"].map(lambda v: f"${v:,.0f}")
    top_customers["avg_order_value"] = top_customers["avg_order_value"].map(lambda v: f"${v:,.0f}")
    top_customers.columns = ["Customer", "Segment", "Nation", "Revenue", "Orders", "Avg Order"]
    st.dataframe(top_customers, use_container_width=True, hide_index=True)


# ── Master Data tab ───────────────────────────────────────────────────────────
with tab_master:
    st.header("Customer Master Data")
    st.caption(
        "Override customer display names and market segments. "
        "Changes are stored in Lakebase and take effect immediately."
    )

    if not LAKEBASE_READY:
        st.error(
            "Lakebase is not configured. After deploying the bundle, copy **PGHOST** and "
            "**ENDPOINT_NAME** from the Lakebase project UI and set them as bundle variables, "
            "then redeploy."
        )
    else:
        try:
            pool = _lakebase_pool()

            with pool.connection() as conn:
                _ensure_schema(conn)
                overrides = _load_overrides(conn)

            customers_raw = run_query("""
                SELECT
                    c_custkey,
                    c_name       AS original_name,
                    c_mktsegment AS original_segment
                FROM samples.tpch.customer
                ORDER BY c_custkey
                LIMIT 50
            """)

            merged = customers_raw.merge(overrides, on="c_custkey", how="left")
            merged["display_name"] = merged["display_name"].fillna(merged["original_name"])
            merged["market_segment"] = merged["market_segment"].fillna(merged["original_segment"])
            display_df = merged[["c_custkey", "display_name", "market_segment"]].copy()

            st.subheader("Edit customer records")
            st.caption("Modify **Display Name** or **Market Segment**, then click Save.")

            edited = st.data_editor(
                display_df,
                column_config={
                    "c_custkey": st.column_config.NumberColumn("Customer Key", disabled=True),
                    "display_name": st.column_config.TextColumn("Display Name"),
                    "market_segment": st.column_config.SelectboxColumn(
                        "Market Segment",
                        options=["AUTOMOBILE", "BUILDING", "FURNITURE", "HOUSEHOLD", "MACHINERY"],
                    ),
                },
                use_container_width=True,
                hide_index=True,
                num_rows="fixed",
            )

            if st.button("Save changes", type="primary"):
                with pool.connection() as conn:
                    _upsert_overrides(conn, edited.to_dict("records"))
                st.success(f"Saved {len(edited)} records to Lakebase.")
                st.cache_data.clear()

        except Exception as exc:
            st.error(f"Could not connect to Lakebase: {exc}")
