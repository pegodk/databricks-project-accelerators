[build-system]
requires = ["hatchling"]
build-backend = "hatchling.build"

[project]
name = "{{ project_slug }}"
version = "0.1.0"
description = "{{ project_slug }} — generated by dpa {{ accelerator }}"
requires-python = ">=3.10"

[tool.hatch.build.targets.wheel]
packages = ["src/{{ project_slug | replace('-', '_') }}"]
