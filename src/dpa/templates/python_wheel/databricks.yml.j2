bundle:
  name: {{ project_slug }}
  deployment:
    lock:
      enabled: false

variables:
  catalog:
    default: {{ cfg.catalog }}
    description: Unity Catalog catalog for the wheel volume
  schema:
    default: {{ cfg.schema }}
    description: Schema for the wheel volume
include:
  - resources/**/*.yml

targets:
  dev:
    mode: development
    default: true
    workspace:
      host: https://<your-dev-workspace-url>
  prod:
    mode: production
    workspace:
      host: https://<your-prod-workspace-url>
    permissions:
      - level: CAN_VIEW
        group_name: users
