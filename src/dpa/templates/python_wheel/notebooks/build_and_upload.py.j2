# Databricks notebook source
# MAGIC %md
# MAGIC # Build & Upload — Python Wheel
# MAGIC
# MAGIC Builds the Python wheel from workspace source files and uploads it to the Unity Catalog Volume.

# COMMAND ----------

dbutils.widgets.text("workspace_file_path", "")
dbutils.widgets.text("catalog", "{{ cfg.catalog }}")
dbutils.widgets.text("schema", "{{ cfg.schema }}")

workspace_file_path = dbutils.widgets.get("workspace_file_path")
catalog = dbutils.widgets.get("catalog")
schema = dbutils.widgets.get("schema")

spark.sql(f"CREATE SCHEMA IF NOT EXISTS {catalog}.{schema}")
spark.sql(f"CREATE VOLUME IF NOT EXISTS {catalog}.{schema}.wheels")
volume_path = f"/Volumes/{catalog}/{schema}/wheels"

# COMMAND ----------

import glob
import os
import subprocess

result = subprocess.run(
    ["pip", "wheel", workspace_file_path, "--no-deps", "--wheel-dir", "/tmp/dist"],
    capture_output=True,
    text=True,
)
if result.returncode != 0:
    raise RuntimeError(f"pip wheel failed:\n{result.stderr}")
print(result.stdout)

# COMMAND ----------

wheels = glob.glob("/tmp/dist/*.whl")
assert wheels, "No wheel produced in /tmp/dist — check that pyproject.toml is present."

for wheel in wheels:
    dest = f"{volume_path}/{os.path.basename(wheel)}"
    dbutils.fs.cp(f"file:{wheel}", dest, recurse=False)
    print(f"Uploaded: {dest}")
