"""Build the Python wheel from workspace files and upload it to a UC Volume."""

import glob
import os
import subprocess
import sys

workspace_file_path = sys.argv[1]
catalog = sys.argv[2]
schema = sys.argv[3]
volume_path = f"/Volumes/{catalog}/{schema}/wheels"

result = subprocess.run(
    ["pip", "wheel", workspace_file_path, "--no-deps", "--wheel-dir", "/tmp/dist"],
    capture_output=True,
    text=True,
)
if result.returncode != 0:
    raise RuntimeError(f"pip wheel failed:\n{result.stderr}")
print(result.stdout)

wheels = glob.glob("/tmp/dist/*.whl")
assert wheels, "No wheel produced in /tmp/dist — check that pyproject.toml is present."

for wheel in wheels:
    dest = f"{volume_path}/{os.path.basename(wheel)}"
    dbutils.fs.cp(f"file:{wheel}", dest, recurse=False)  # noqa: F821
    print(f"Uploaded: {dest}")
