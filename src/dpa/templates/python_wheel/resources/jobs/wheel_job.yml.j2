{% set slug = project_slug | replace('-', '_') %}
resources:
  jobs:
    {{ slug }}_wheel:
      name: "dpa-{{ project_slug }}"
      environments:
        - environment_key: default
          spec:
            client: "1"
      tasks:
        - task_key: build_and_upload
          environment_key: default
          spark_python_task:
            python_file: ${workspace.file_path}/notebooks/build_and_upload.py
            parameters:
              - ${workspace.file_path}
              - ${var.catalog}
              - ${var.schema}

        - task_key: verify_imports
          depends_on:
            - task_key: build_and_upload
          environment_key: default
          spark_python_task:
            python_file: ${workspace.file_path}/notebooks/verify_imports.py
            parameters:
              - ${var.catalog}
              - ${var.schema}
