# Databricks Asset Bundle — generated by dpa {{ accelerator }}

bundle:
  name: {{ project_slug }}

variables:
  catalog:
    description: Unity Catalog in which to create the metric view schema
    default: {{ cfg.catalog }}
  schema:
    description: Schema in which to create the metric views
    default: {{ cfg.schema }}

include:
  - resources/**/*.yml

targets:
  dev:
    mode: development
    default: true
    workspace:
      host: ${workspace.host}
    variables:
      schema: {{ cfg.schema }}_dev

  prod:
    mode: production
    workspace:
      host: ${workspace.host}
    permissions:
      - level: CAN_VIEW
        group_name: users
