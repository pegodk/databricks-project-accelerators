[build-system]
requires = ["setuptools>=68", "wheel"]
build-backend = "setuptools.backends.legacy:build"

[project]
name = "{{ project_slug | replace('-', '_') }}_transforms"
version = "0.1.0"
description = "Custom PySpark transformations for {{ project_slug }}"
requires-python = ">=3.10"

[tool.setuptools.packages.find]
where = ["src"]
