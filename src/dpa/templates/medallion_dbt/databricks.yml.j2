bundle:
  name: {{ project_slug }}
  deployment:
    lock:
      enabled: false

variables:
  catalog:
    default: {{ cfg.catalog }}
    description: Unity Catalog catalog for dbt output schemas
  schema:
    default: {{ cfg.schema }}
    description: Base schema for dbt models (bronze/silver/gold appended automatically)
  warehouse_id:
    default: {{ cfg.warehouse_id }}
    description: SQL warehouse ID used by the dbt job task
  node_type_id:
    default: {{ cfg.node_type_id }}
    description: "VM size for the dbt job cluster (Standard_DS3_v2 for Azure, i3.xlarge for AWS, n2-highmem-4 for GCP)"

include:
  - resources/**/*.yml

targets:
  dev:
    mode: development
    default: true
    workspace:
      host: https://<your-dev-workspace-url>
  prod:
    mode: production
    workspace:
      host: https://<your-prod-workspace-url>
    permissions:
      - level: CAN_VIEW
        group_name: users
