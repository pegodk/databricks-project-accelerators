bundle:
  name: {{ project_slug }}
  deployment:
    lock:
      enabled: false

variables:
  bronze_catalog:
    default: {{ cfg.bronze_catalog }}
    description: Unity Catalog for the bronze (raw) layer
  silver_catalog:
    default: {{ cfg.silver_catalog }}
    description: Unity Catalog for the silver (cleansed) layer
  gold_catalog:
    default: {{ cfg.gold_catalog }}
    description: Unity Catalog for the gold (business aggregate) layer
  bronze_schema:
    default: {{ cfg.bronze_schema }}
    description: Schema for raw ingested data (source-specific, e.g. tpch)
  silver_schema:
    default: {{ cfg.silver_schema }}
    description: Schema for cleansed data (source-specific, e.g. tpch)
  gold_schema:
    default: {{ cfg.gold_schema }}
    description: Schema for business-level aggregates (data-product-specific, e.g. tpch_model)
  warehouse_id:
    lookup:
      sql_warehouse: "Serverless Starter Warehouse"
include:
  - resources/**/*.yml

targets:
  dev:
    mode: development
    default: true
    workspace:
      host: https://<your-dev-workspace-url>
  prod:
    mode: production
    workspace:
      host: https://<your-prod-workspace-url>
    permissions:
      - level: CAN_VIEW
        group_name: users
