{% set slug = project_slug | replace('-', '_') %}
resources:
  jobs:
    {{ slug }}_job:
      name: "dpa-{{ project_slug }}"
      tasks:
        - task_key: dbt_run
          dbt_task:
            project_directory: "${workspace.file_path}"
            source: WORKSPACE
            commands:
              - "dbt deps"
              - "dbt run"
              - "dbt test"
            warehouse_id: ${var.warehouse_id}
            catalog: ${var.gold_catalog}
            schema: ${var.gold_schema}
      schedule:
        quartz_cron_expression: "0 0 6 * * ?"
        timezone_id: UTC
        pause_status: PAUSED
