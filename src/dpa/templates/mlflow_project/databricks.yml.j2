bundle:
  name: {{ project_slug }}
  deployment:
    lock:
      enabled: false

workspace:
  host: https://<your-workspace-url>  # TODO: replace with your workspace URL

variables:
  catalog:
    default: {{ cfg.catalog }}
    description: Unity Catalog catalog for the model registry and schema
  schema:
    default: {{ cfg.schema }}
    description: Schema for the registered model
  experiment_name:
    default: {{ cfg.experiment_name }}
    description: Workspace path for the MLflow experiment
  model_name:
    default: {{ cfg.model_name }}
    description: Registered model name (registered as catalog.schema.model_name)
  node_type_id:
    default: {{ cfg.node_type_id }}
    description: "VM size (Standard_DS3_v2 for Azure, i3.xlarge for AWS, n2-highmem-4 for GCP)"

include:
  - resources/jobs/*.yml
  - resources/schemas/*.yml

targets:
  dev:
    mode: development
    default: true
  prod:
    mode: production
    permissions:
      - level: CAN_VIEW
        group_name: users
