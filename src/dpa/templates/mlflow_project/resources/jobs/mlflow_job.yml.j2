{% set slug = project_slug | replace('-', '_') %}
resources:
  jobs:
    {{ slug }}_pipeline:
      name: "dpa-{{ project_slug }} — Train, Register & Score"
      environments:
        - environment_key: default
          spec:
            client: "1"
            dependencies:
              - scikit-learn
              - mlflow
      tasks:
        - task_key: train
          environment_key: default
          notebook_task:
            notebook_path: ${workspace.file_path}/notebooks/train.py
            base_parameters:
              catalog: ${var.catalog}
              schema: ${var.schema}
              experiment_name: ${var.experiment_name}
              model_name: ${var.model_name}

        - task_key: register
          depends_on:
            - task_key: train
          environment_key: default
          notebook_task:
            notebook_path: ${workspace.file_path}/notebooks/register.py
            base_parameters:
              catalog: ${var.catalog}
              schema: ${var.schema}
              experiment_name: ${var.experiment_name}
              model_name: ${var.model_name}

        - task_key: score
          depends_on:
            - task_key: register
          environment_key: default
          notebook_task:
            notebook_path: ${workspace.file_path}/notebooks/score.py
            base_parameters:
              catalog: ${var.catalog}
              schema: ${var.schema}
              model_name: ${var.model_name}
