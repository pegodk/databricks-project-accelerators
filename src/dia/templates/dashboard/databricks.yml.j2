# Databricks Asset Bundle — generated by dia {{ accelerator }}
# Edit the catalog, schema, workspace host, and warehouse ID to match your environment.

bundle:
  name: {{ project_slug }}

variables:
  catalog:
    description: Unity Catalog in which to create the metric view schema
    default: {{ cfg.catalog }}
  schema:
    description: Schema in which to create the metric views
    default: {{ cfg.schema }}
  sql_warehouse_id:
    description: ID of the SQL warehouse used to run the metric view setup job
    default: ""

include:
  - resources/**/*.yml

targets:
  dev:
    mode: development
    default: true
    workspace:
      host: ${workspace.host}
    variables:
      schema: {{ cfg.schema }}_dev

  prod:
    mode: production
    workspace:
      host: ${workspace.host}
    permissions:
      - level: CAN_VIEW
        group_name: users
