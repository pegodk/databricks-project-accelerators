{% set slug = project_slug | replace('-', '_') %}
resources:
  jobs:
    {{ slug }}_setup_views:
      name: "[${bundle.target}] {{ project_slug }} — Setup Metric Views"
      tasks:
        - task_key: create_metric_views
          sql_task:
            warehouse_id: ${var.sql_warehouse_id}
            file:
              path: /Workspace/${workspace.file_path}/src/sql/metric_views.sql
