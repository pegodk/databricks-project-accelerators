# pyproject.toml for the embedded framework package.
# The DLT pipeline environment installs this via editable pip install
# (see resources/pipelines/ — the /Workspace/... dependency).

[build-system]
requires = ["hatchling"]
build-backend = "hatchling.build"

[project]
name = "{{ project_slug }}-framework"
version = "0.1.0"
description = "Embedded pipeline framework for {{ project_slug }}"
requires-python = ">=3.10"
dependencies = [
    "databricks-dlt>=0.3.0",
    "pyspark>=3.5.0",
    "faker>=25",
]

[tool.hatch.build.targets.wheel]
packages = ["src/framework"]

[tool.hatch.build.targets.wheel.sources]
"src" = ""
