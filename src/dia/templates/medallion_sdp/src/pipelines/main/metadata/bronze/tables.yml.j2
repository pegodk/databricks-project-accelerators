# Bronze layer table metadata
# source_type: fake — data is generated by the industry fake data source
# Edit to swap in a real source (source_type: table, source: catalog.schema.table_name)
{% for table in cfg.bronze_tables %}
- source_type: fake
  source_class: {{ cfg.source_class }}
  destination: {{ table.name }}
  primary_keys:
{% for key in table.primary_keys %}
    - {{ key }}
{% endfor %}
  description: "{{ table.description }}"
{% endfor %}
