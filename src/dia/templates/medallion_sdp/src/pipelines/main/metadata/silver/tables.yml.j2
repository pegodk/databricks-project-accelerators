# Silver layer table metadata
# source: bronze DLT table name to read from
# expectations_fail_update: stop the pipeline update on violation
# expectations_drop_row:    silently drop the offending row
# expectations_warn:        log the violation, let the row through
{% for table in cfg.bronze_tables %}
{% set exps = cfg.get('silver_expectations', {}).get(table.name, {}) %}
- source: {{ table.name }}
  destination: {{ table.name }}
  primary_keys:
{% for key in table.primary_keys %}
    - {{ key }}
{% endfor %}
  description: "{{ table.description }} (validated)"
{% if exps.get('fail_update') %}
  expectations_fail_update:
{% for rule_name, rule_expr in exps['fail_update'].items() %}
    {{ rule_name }}: "{{ rule_expr }}"
{% endfor %}
{% endif %}
{% if exps.get('drop_row') %}
  expectations_drop_row:
{% for rule_name, rule_expr in exps['drop_row'].items() %}
    {{ rule_name }}: "{{ rule_expr }}"
{% endfor %}
{% endif %}
{% if exps.get('warn') %}
  expectations_warn:
{% for rule_name, rule_expr in exps['warn'].items() %}
    {{ rule_name }}: "{{ rule_expr }}"
{% endfor %}
{% endif %}
{% endfor %}
